{
  "name": "vsimage",
  "displayName": "VS Code Image Editor",
  "description": "Premium image editor to crop, resize, and convert images inside VS Code with clipboard paste.",
  "version": "1.0.0",
  "publisher": "myside",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsimage.newEditor",
        "title": "Image: New Empty Image Editor",
        "category": "Image Editor"
      }
    ],
    "customEditors": [
      {
        "viewType": "vsimage.editor",
        "displayName": "VS Code Image Editor",
        "selector": [
          {
            "filenamePattern": "*.{png,jpg,jpeg,webp,gif}"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "test": "node out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^16.x",
    "@types/mocha": "^10.0.1",
    "typescript": "^5.1.3",
    "ts-loader": "^9.4.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1",
    "@vscode/test-electron": "^2.3.3"
  }
}
